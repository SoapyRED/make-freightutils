{
  "name": "uldLookup",
  "label": "Find ULD (Unit Load Device)",
  "description": "Look up an air-freight ULD spec by type code (AKE, PMC, PLA, etc.).",
  "typeId": 9,
  "connection": "apiKey",
  "api": {
    "url": "/uld",
    "method": "GET",
    "qs": { "type": "{{parameters.type}}" },
    "response": {
      "iterate": "[{{body.result}}]",
      "output": "{{item}}"
    }
  },
  "expect": [
    { "name": "type", "label": "ULD Type", "type": "text", "required": true, "default": "AKE", "help": "ULD type code, e.g. AKE (LD3), PMC, PLA" }
  ],
  "interface": [
    { "name": "code", "label": "Code", "type": "text" },
    { "name": "name", "label": "Name", "type": "text" },
    { "name": "internal_volume_m3", "label": "Internal Volume (m³)", "type": "number" },
    { "name": "max_gross_kg", "label": "Max Gross Weight (kg)", "type": "number" }
  ],
  "samples": {
    "code": "AKE",
    "name": "LD3",
    "internal_volume_m3": 4.3,
    "max_gross_kg": 1588,
    "external_length_cm": 156,
    "external_width_cm": 153,
    "external_height_cm": 163
  }
}
