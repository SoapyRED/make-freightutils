{
  "name": "ukDuty",
  "label": "Calculate UK Import Duty",
  "description": "UK duty + VAT for a commodity code using live GOV.UK Trade Tariff data.",
  "typeId": 4,
  "connection": "apiKey",
  "api": {
    "url": "/duty",
    "method": "POST",
    "body": {
      "commodityCode": "{{parameters.commodityCode}}",
      "originCountry": "{{parameters.originCountry}}",
      "customsValue": "{{parameters.customsValue}}"
    },
    "response": { "output": "{{body}}" }
  },
  "expect": [
    { "name": "commodityCode", "label": "Commodity Code", "type": "text", "required": true, "default": "0901110000", "help": "10-digit HS commodity code" },
    { "name": "originCountry", "label": "Origin Country (ISO Alpha-2)", "type": "text", "required": true, "default": "BR", "help": "Two-letter country code, e.g. BR, CN, US" },
    { "name": "customsValue", "label": "Customs Value (GBP)", "type": "number", "required": true, "default": 5000 }
  ],
  "interface": [
    { "name": "commodityCode", "label": "Commodity Code", "type": "text" },
    { "name": "duty_rate_percent", "label": "Duty Rate (%)", "type": "number" },
    { "name": "duty_gbp", "label": "Duty (GBP)", "type": "number" },
    { "name": "vat_rate_percent", "label": "VAT Rate (%)", "type": "number" },
    { "name": "vat_gbp", "label": "VAT (GBP)", "type": "number" },
    { "name": "total_gbp", "label": "Total Duty + VAT (GBP)", "type": "number" },
    { "name": "preferential", "label": "Preferential Rate", "type": "boolean" }
  ],
  "samples": {
    "commodityCode": "0901110000",
    "originCountry": "BR",
    "customsValue": 5000,
    "duty_rate_percent": 0,
    "duty_gbp": 0,
    "vat_rate_percent": 20,
    "vat_gbp": 1000,
    "total_gbp": 1000,
    "preferential": false
  }
}
